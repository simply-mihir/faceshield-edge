{
  "name": "react-native-worklets-core",
  "version": "1.6.3",
  "summary": "A Worklet runner for React Native",
  "homepage": "https://github.com/margelo/react-native-worklets-core#readme",
  "license": "MIT",
  "authors": "Christian Falch <christian.falch@gmail.com> (https://github.com/chrfalch)",
  "platforms": {
    "ios": "11.0"
  },
  "source": {
    "git": "https://github.com/margelo/react-native-worklets-core.git",
    "tag": "1.6.3"
  },
  "source_files": [
    "ios/**/*.{h,m,mm}",
    "cpp/**/*.{h,cpp}"
  ],
  "pod_target_xcconfig": {
    "DEFINES_MODULE": "YES",
    "HEADER_SEARCH_PATHS": "\"$(PODS_ROOT)/boost\" \"$(PODS_ROOT)/Headers/Private/Yoga\"",
    "CLANG_CXX_LANGUAGE_STANDARD": "c++20"
  },
  "compiler_flags": "$(inherited) -DFOLLY_NO_CONFIG -DFOLLY_MOBILE=1 -DFOLLY_USE_LIBCPP=1 -DFOLLY_CFG_NO_COROUTINES=1 -Wno-comma -Wno-shorten-64-to-32",
  "dependencies": {
    "React-Core": [],
    "RCT-Folly": [
      "2022.05.16.00"
    ],
    "glog": []
  }
}
