# FaceShield Edge — Environment Variables
# Copy to .env and fill in your values (never commit .env to git)

# AWS API Gateway endpoint (from `sam deploy` Outputs → ApiEndpoint)
AWS_API_ENDPOINT=https://xxxxxxxxxx.execute-api.ap-south-1.amazonaws.com/prod

# AWS region
AWS_REGION=ap-south-1

# Site/location tag written into attendance records
LOCATION_TAG=SITE-DEFAULT

# JWT secret — must match the value in AWS Secrets Manager (faceshield/jwt_secret)
# Only needed for local Lambda testing, NOT deployed to the app
JWT_SECRET=your-jwt-secret-here

# Device secret used in SHA-256 tamper hash
# Must match AWS Secrets Manager value (faceshield/device_secret)
DEVICE_SECRET=your-device-secret-here
