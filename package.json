{
  "name": "faceshield-edge",
  "version": "2.0.0",
  "description": "Offline Facial Authentication & Liveness Verification — FaceShield Edge v2.0",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "start": "react-native start",
    "test": "jest",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@react-native-community/netinfo": "^11.3.1",
    "@react-navigation/native": "^6.1.17",
    "@react-navigation/native-stack": "^6.9.17",
    "@react-navigation/stack": "^6.3.29",
    "@types/uuid": "^9.0.8",
    "react": "18.2.0",
    "react-native": "0.73.6",
    "react-native-fast-tflite": "^1.5.0",
    "react-native-keychain": "^8.2.0",
    "react-native-mmkv": "^2.12.2",
    "react-native-safe-area-context": "^4.9.0",
    "react-native-screens": "^3.31.1",
    "react-native-vision-camera": "^3.9.1",
    "react-native-worklets-core": "^1.6.3",
    "uuid": "^9.0.1",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@babel/preset-env": "^7.20.0",
    "@babel/runtime": "^7.20.0",
    "@react-native/babel-preset": "0.73.21",
    "@react-native/eslint-config": "0.73.2",
    "@react-native/metro-config": "0.73.5",
    "@react-native/typescript-config": "0.73.1",
    "@types/jest": "^29.5.12",
    "@types/react": "^18.2.6",
    "@types/react-native": "^0.73.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "prettier": "^3.0.3",
    "typescript": "5.0.4"
  },
  "jest": {
    "preset": "react-native",
    "moduleNameMapper": {
      "react-native-mmkv": "<rootDir>/__mocks__/react-native-mmkv.js",
      "react-native-keychain": "<rootDir>/__mocks__/react-native-keychain.js"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!(react-native|@react-native|react-native-vision-camera|react-native-fast-tflite|react-native-mmkv|react-native-keychain|@react-native-community)/)"
    ]
  },
  "engines": {
    "node": ">=18"
  }
}
